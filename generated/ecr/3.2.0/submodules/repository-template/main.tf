module "ecr_repository-template" {
  source                                = "terraform-aws-modules/ecr/aws//modules/repository-template"
  version                               = "3.2.0"
  description                           = var.description
  image_tag_mutability_exclusion_filter = var.image_tag_mutability_exclusion_filter
  credential_arn                        = var.credential_arn
  iam_role_name                         = var.iam_role_name
  applied_for                           = var.applied_for
  lifecycle_policy                      = var.lifecycle_policy
  prefix                                = var.prefix
  upstream_registry_url                 = var.upstream_registry_url
  create_repository_policy              = var.create_repository_policy
  iam_role_use_name_prefix              = var.iam_role_use_name_prefix
  create                                = var.create
  region                                = var.region
  encryption_type                       = var.encryption_type
  resource_tags                         = var.resource_tags
  repository_read_access_arns           = var.repository_read_access_arns
  repository_lambda_read_access_arns    = var.repository_lambda_read_access_arns
  repository_policy_statements          = var.repository_policy_statements
  create_iam_role                       = var.create_iam_role
  tags                                  = var.tags
  image_tag_mutability                  = var.image_tag_mutability
  repository_policy                     = var.repository_policy
  custom_role_arn                       = var.custom_role_arn
  repository_read_write_access_arns     = var.repository_read_write_access_arns
  iam_role_path                         = var.iam_role_path
  iam_role_description                  = var.iam_role_description
  iam_role_permissions_boundary         = var.iam_role_permissions_boundary
  iam_role_tags                         = var.iam_role_tags
  create_pull_through_cache_rule        = var.create_pull_through_cache_rule
  kms_key_arn                           = var.kms_key_arn
}
