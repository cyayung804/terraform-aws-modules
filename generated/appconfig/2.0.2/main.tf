module "appconfig" {
  source                                             = "terraform-aws-modules/appconfig/aws"
  version                                            = "2.0.2"
  s3_configuration_object_key                        = var.s3_configuration_object_key
  use_s3_configuration                               = var.use_s3_configuration
  hosted_config_version_content                      = var.hosted_config_version_content
  deployment_strategy_deployment_duration_in_minutes = var.deployment_strategy_deployment_duration_in_minutes
  config_profile_type                                = var.config_profile_type
  config_profile_location_uri                        = var.config_profile_location_uri
  config_profile_tags                                = var.config_profile_tags
  retrieval_role_permissions_boundary                = var.retrieval_role_permissions_boundary
  use_ssm_parameter_configuration                    = var.use_ssm_parameter_configuration
  use_ssm_document_configuration                     = var.use_ssm_document_configuration
  deployment_strategy_final_bake_time_in_minutes     = var.deployment_strategy_final_bake_time_in_minutes
  deployment_strategy_growth_factor                  = var.deployment_strategy_growth_factor
  ssm_parameter_configuration_arn                    = var.ssm_parameter_configuration_arn
  use_hosted_configuration                           = var.use_hosted_configuration
  deployment_strategy_replicate_to                   = var.deployment_strategy_replicate_to
  deployment_tags                                    = var.deployment_tags
  create_retrieval_role                              = var.create_retrieval_role
  deployment_strategy_growth_type                    = var.deployment_strategy_growth_type
  deployment_description                             = var.deployment_description
  deployment_configuration_version                   = var.deployment_configuration_version
  name                                               = var.name
  s3_configuration_bucket_arn                        = var.s3_configuration_bucket_arn
  create_deployment_strategy                         = var.create_deployment_strategy
  deployment_strategy_description                    = var.deployment_strategy_description
  environments                                       = var.environments
  config_profile_validator                           = var.config_profile_validator
  retrieval_role_use_name_prefix                     = var.retrieval_role_use_name_prefix
  retrieval_role_path                                = var.retrieval_role_path
  retrieval_role_tags                                = var.retrieval_role_tags
  deployment_strategy_tags                           = var.deployment_strategy_tags
  tags                                               = var.tags
  description                                        = var.description
  config_profile_description                         = var.config_profile_description
  ssm_document_configuration_arn                     = var.ssm_document_configuration_arn
  hosted_config_version_content_type                 = var.hosted_config_version_content_type
  deployment_strategy_id                             = var.deployment_strategy_id
  create                                             = var.create
  retrieval_role_name                                = var.retrieval_role_name
  deployment_strategy_name                           = var.deployment_strategy_name
  hosted_config_version_description                  = var.hosted_config_version_description
  config_profile_name                                = var.config_profile_name
  config_profile_retrieval_role_arn                  = var.config_profile_retrieval_role_arn
  retrieval_role_description                         = var.retrieval_role_description
}
