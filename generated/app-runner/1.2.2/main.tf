  service_name                           = var.service_name
  auto_scaling_configuration_arn         = var.auto_scaling_configuration_arn
  access_iam_role_path                   = var.access_iam_role_path
  ingress_vpc_endpoint_id                = var.ingress_vpc_endpoint_id
