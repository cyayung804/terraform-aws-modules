  create_ingress_vpc_connection          = var.create_ingress_vpc_connection
  vpc_connector_name                     = var.vpc_connector_name
  vpc_connector_security_groups          = var.vpc_connector_security_groups
  access_iam_role_use_name_prefix        = var.access_iam_role_use_name_prefix
  instance_configuration                 = var.instance_configuration
