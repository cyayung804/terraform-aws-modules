  create_access_iam_role                 = var.create_access_iam_role
  instance_iam_role_use_name_prefix      = var.instance_iam_role_use_name_prefix
  instance_iam_role_path                 = var.instance_iam_role_path
  instance_iam_role_description          = var.instance_iam_role_description
  instance_iam_role_policies             = var.instance_iam_role_policies
  create                                 = var.create
  observability_configuration            = var.observability_configuration
  source_configuration                   = var.source_configuration
